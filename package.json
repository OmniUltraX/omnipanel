{
  "name": "omnipanel",
  "version": "0.1.0",
  "private": true,
  "description": "AI-native cross-platform engineering workstation",
  "scripts": {
    "install:frontend": "npm ci --prefix frontend",
    "install:website": "npm ci --prefix website",
    "install:all": "npm run install:frontend && npm run install:website",
    "gen:bindings": "node scripts/gen-ipc-bindings.mjs",
    "check:ipc-registry": "node scripts/check-ipc-command-registry.mjs",
    "dev:frontend": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "typecheck": "tsc -b"
  },
  "devDependencies": {
    "typescript": "~6.0.2"
  }
}
